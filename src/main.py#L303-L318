    def _toggle_dynamic_scan(self):
        """Activa o desactiva el escaneo dinámico."""
        if self.is_dynamic_running:
            self.is_dynamic_running = False
            self.tts.speak("Escaneo dinámico desactivado.", interrupt=True)
            logger.info("Escaneo dinámico detenido.")
        else:
            self._release_modifiers()
            self.is_dynamic_running = True
            self.tts.speak("Escaneo dinámico activado.", interrupt=True)
            logger.info("Escaneo dinámico iniciado.")
            self.dynamic_thread = threading.Thread(target=self._dynamic_scan_loop, daemon=True)
            self.dynamic_thread.start()
